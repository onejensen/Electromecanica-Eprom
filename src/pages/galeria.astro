---
import Layout from '../layouts/Layout.astro';

const imagenes = [
  {
    src: 'https://images.unsplash.com/photo-1599256871679-6a8e9b3a0b9e?w=800&q=80',
    alt: 'Taller electromecánica Eprom - Zona de trabajo principal',
  },
  {
    src: 'https://images.unsplash.com/photo-1619642751034-765dfdf7c58e?w=800&q=80',
    alt: 'Diagnóstico electrónico con equipos de última generación',
  },
  {
    src: 'https://images.unsplash.com/photo-1580274455191-1c62238fa333?w=800&q=80',
    alt: 'Trabajos de electricidad del automóvil en Palma',
  },
  {
    src: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80',
    alt: 'Reparación de motor en taller Eprom Mallorca',
  },
  {
    src: 'https://images.unsplash.com/photo-1609349093172-5b44d9a72d39?w=800&q=80',
    alt: 'Equipo de mecánicos profesionales en Palma',
  },
  {
    src: 'https://images.unsplash.com/photo-1530046339160-ce3e530c7d2f?w=800&q=80',
    alt: 'Herramientas especializadas de electromecánica',
  },
  {
    src: 'https://images.unsplash.com/photo-1493238792000-8113da705763?w=800&q=80',
    alt: 'Revisión de sistema de frenos en taller Eprom',
  },
  {
    src: 'https://images.unsplash.com/photo-1547036967-23d11aacaee0?w=800&q=80',
    alt: 'Mantenimiento preventivo de vehículos en Mallorca',
  },
  {
    src: 'https://images.unsplash.com/photo-1504222490345-c075b7c1d94e?w=800&q=80',
    alt: 'Reparación del sistema eléctrico del coche',
  },
];
---

<Layout title="Galería de Trabajos" description="Galería de trabajos realizados en Electromecánica Eprom. Taller de electromecánica en Palma de Mallorca especializado en diagnóstico y reparación.">
  <!-- Header -->
  <section class="bg-primary-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Galería</h1>
      <p class="text-neutral-200 text-lg max-w-2xl">Conoce nuestras instalaciones y algunos de los trabajos que realizamos en nuestro taller de electromecánica en Palma.</p>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {imagenes.map((img) => (
          <div class="group relative aspect-[4/3] rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
            <img
              src={img.src}
              alt={img.alt}
              class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-4">
              <p class="text-white text-sm font-medium">{img.alt}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-12 text-center">
        <p class="text-neutral-500 text-sm">Fotografías reales de talleres mecánicos especializados en electromecánica y diagnóstico del automóvil.</p>
      </div>
    </div>
  </section>
</Layout>
