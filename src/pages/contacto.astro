---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto - Pide Tu Cita" description="Contacta con Electromecánica Eprom en Palma de Mallorca. Pide tu cita por teléfono, WhatsApp o formulario. C/ Joan Fuster i Ortells, 24.">
  <!-- Header -->
  <section style="background:#1A1A1A;padding:80px 0 48px;position:relative;border-bottom:3px solid #F5A623;">
    <div style="max-width:1280px;margin:0 auto;padding:0 24px;">
      <div style="display:inline-block;background:#F5A623;color:#111111;font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;padding:6px 16px;margin-bottom:16px;">Contacto</div>
      <h1 style="font-family:'Bebas Neue',sans-serif;font-size:clamp(2.5rem,5vw,5rem);color:#F0F0F0;line-height:1.0;letter-spacing:0.04em;">Contacta con Nosotros</h1>
      <div style="width:80px;height:3px;background:#F5A623;margin-top:16px;"></div>
      <p style="color:#9ca3af;margin-top:16px;max-width:600px;font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;letter-spacing:0.02em;">¿Necesitas una revisión o reparación? Contacta con nosotros y te atenderemos lo antes posible.</p>
    </div>
  </section>

  <section style="padding:64px 0;background:#1A1A1A;">
    <div style="max-width:1280px;margin:0 auto;padding:0 24px;">
      <div class="contact-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:48px;">
        <!-- Formulario -->
        <div>
          <h2 style="font-family:'Bebas Neue',sans-serif;font-size:2rem;color:#F0F0F0;letter-spacing:0.04em;margin-bottom:24px;">Solicita tu cita</h2>
          <form action="https://formspree.io/f/PLACEHOLDER" method="POST" style="display:flex;flex-direction:column;gap:20px;">
            <div>
              <label for="nombre" style="display:block;font-size:0.85rem;font-family:'Barlow Condensed',sans-serif;color:#9ca3af;margin-bottom:6px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;">Nombre completo *</label>
              <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" style="width:100%;padding:12px 16px;background:#242424;border:1px solid #444;border-radius:2px;color:#F0F0F0;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;transition:border-color 0.15s;" onfocus="this.style.borderColor='#F5A623'" onblur="this.style.borderColor='#444'">
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;" class="form-row">
              <div>
                <label for="telefono" style="display:block;font-size:0.85rem;font-family:'Barlow Condensed',sans-serif;color:#9ca3af;margin-bottom:6px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;">Teléfono *</label>
                <input type="tel" id="telefono" name="telefono" required placeholder="600 000 000" style="width:100%;padding:12px 16px;background:#242424;border:1px solid #444;border-radius:2px;color:#F0F0F0;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;transition:border-color 0.15s;" onfocus="this.style.borderColor='#F5A623'" onblur="this.style.borderColor='#444'">
              </div>
              <div>
                <label for="email" style="display:block;font-size:0.85rem;font-family:'Barlow Condensed',sans-serif;color:#9ca3af;margin-bottom:6px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;">Email</label>
                <input type="email" id="email" name="email" placeholder="tu@email.com" style="width:100%;padding:12px 16px;background:#242424;border:1px solid #444;border-radius:2px;color:#F0F0F0;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;transition:border-color 0.15s;" onfocus="this.style.borderColor='#F5A623'" onblur="this.style.borderColor='#444'">
              </div>
            </div>
            <div>
              <label for="vehiculo" style="display:block;font-size:0.85rem;font-family:'Barlow Condensed',sans-serif;color:#9ca3af;margin-bottom:6px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;">Vehículo (marca, modelo, año)</label>
              <input type="text" id="vehiculo" name="vehiculo" placeholder="Ej: Seat León 2019" style="width:100%;padding:12px 16px;background:#242424;border:1px solid #444;border-radius:2px;color:#F0F0F0;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;transition:border-color 0.15s;" onfocus="this.style.borderColor='#F5A623'" onblur="this.style.borderColor='#444'">
            </div>
            <div>
              <label for="servicio" style="display:block;font-size:0.85rem;font-family:'Barlow Condensed',sans-serif;color:#9ca3af;margin-bottom:6px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;">Servicio requerido</label>
              <select id="servicio" name="servicio" style="width:100%;padding:12px 16px;background:#242424;border:1px solid #444;border-radius:2px;color:#F0F0F0;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;transition:border-color 0.15s;" onfocus="this.style.borderColor='#F5A623'" onblur="this.style.borderColor='#444'">
                <option value="">Selecciona un servicio</option>
                <option value="diagnostico">Diagnóstico electrónico</option>
                <option value="electricidad">Electricidad del automóvil</option>
                <option value="mantenimiento">Mantenimiento preventivo</option>
                <option value="motor">Reparación de motor</option>
                <option value="aire">Aire acondicionado</option>
                <option value="frenos">Sistema de frenado</option>
                <option value="pre-itv">Pre-ITV</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div>
              <label for="mensaje" style="display:block;font-size:0.85rem;font-family:'Barlow Condensed',sans-serif;color:#9ca3af;margin-bottom:6px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;">Describe tu problema o consulta</label>
              <textarea id="mensaje" name="mensaje" rows="4" placeholder="Cuéntanos qué le pasa a tu vehículo..." style="width:100%;padding:12px 16px;background:#242424;border:1px solid #444;border-radius:2px;color:#F0F0F0;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;resize:vertical;transition:border-color 0.15s;" onfocus="this.style.borderColor='#F5A623'" onblur="this.style.borderColor='#444'"></textarea>
            </div>
            <button type="submit" style="width:100%;padding:16px;background:#F5A623;color:#111111;font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;font-weight:700;border:none;border-radius:2px;cursor:pointer;text-transform:uppercase;letter-spacing:0.1em;transition:background 0.15s,transform 0.15s;" onmouseover="this.style.background='#c97d10';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#F5A623';this.style.transform='translateY(0)'">
              Enviar Solicitud de Cita
            </button>
            <p style="font-size:0.8rem;color:#666;text-align:center;font-family:'Barlow Condensed',sans-serif;">Te contactaremos en menos de 24 horas para confirmar tu cita.</p>
          </form>
        </div>

        <!-- Info de contacto -->
        <div style="display:flex;flex-direction:column;gap:32px;">
          <div>
            <h2 style="font-family:'Bebas Neue',sans-serif;font-size:2rem;color:#F0F0F0;letter-spacing:0.04em;margin-bottom:24px;">Información de contacto</h2>
            <div style="display:flex;flex-direction:column;gap:20px;">
              <div style="display:flex;align-items:flex-start;gap:16px;">
                <div style="width:44px;height:44px;background:#F5A623;border-radius:2px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg xmlns="http://www.w3.org/2000/svg" style="height:22px;width:22px;color:#111111;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:#F0F0F0;letter-spacing:0.04em;">Dirección</h3>
                  <p style="color:#9ca3af;font-family:'Barlow Condensed',sans-serif;font-size:0.95rem;line-height:1.5;">Carrer de Joan Fuster i Ortells, 24, Nord<br>07010 Palma, Illes Balears</p>
                </div>
              </div>
              <div style="display:flex;align-items:flex-start;gap:16px;">
                <div style="width:44px;height:44px;background:#F5A623;border-radius:2px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg xmlns="http://www.w3.org/2000/svg" style="height:22px;width:22px;color:#111111;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:#F0F0F0;letter-spacing:0.04em;">Teléfono</h3>
                  <a href="tel:+34971906236" style="color:#F5A623;font-family:'Barlow Condensed',sans-serif;font-size:1rem;text-decoration:none;font-weight:600;">971 906 236</a>
                </div>
              </div>
              <div style="display:flex;align-items:flex-start;gap:16px;">
                <div style="width:44px;height:44px;background:#F5A623;border-radius:2px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg xmlns="http://www.w3.org/2000/svg" style="height:22px;width:22px;color:#111111;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:#F0F0F0;letter-spacing:0.04em;">Email</h3>
                  <a href="mailto:electromecanicaeprom@gmail.com" style="color:#F5A623;font-family:'Barlow Condensed',sans-serif;font-size:1rem;text-decoration:none;font-weight:600;">electromecanicaeprom@gmail.com</a>
                </div>
              </div>
              <div style="display:flex;align-items:flex-start;gap:16px;">
                <div style="width:44px;height:44px;background:#25d366;border-radius:2px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg xmlns="http://www.w3.org/2000/svg" style="height:22px;width:22px;color:#fff;" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </div>
                <div>
                  <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:#F0F0F0;letter-spacing:0.04em;">WhatsApp</h3>
                  <a href="https://wa.me/34625086015?text=Hola,%20me%20gustaría%20solicitar%20información" target="_blank" rel="noopener noreferrer" style="color:#25d366;font-family:'Barlow Condensed',sans-serif;font-size:1rem;text-decoration:none;font-weight:600;">Enviar mensaje (625 08 60 15)</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Horario -->
          <div style="background:#242424;border-top:3px solid #F5A623;border-left:1px solid #333;border-right:1px solid #333;border-bottom:1px solid #333;border-radius:2px;padding:24px;">
            <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:#F0F0F0;letter-spacing:0.04em;margin-bottom:16px;">Horario de Atención</h3>
            <div style="display:flex;flex-direction:column;gap:8px;">
              <div style="display:flex;justify-content:space-between;font-family:'Barlow Condensed',sans-serif;font-size:0.95rem;"><span style="color:#9ca3af;">Lunes - Jueves</span><span style="color:#F0F0F0;font-weight:600;">08:00 - 17:00</span></div>
              <div style="display:flex;justify-content:space-between;font-family:'Barlow Condensed',sans-serif;font-size:0.95rem;"><span style="color:#9ca3af;">Viernes</span><span style="color:#F0F0F0;font-weight:600;">08:00 - 14:00</span></div>
              <div style="display:flex;justify-content:space-between;font-family:'Barlow Condensed',sans-serif;font-size:0.95rem;margin-top:4px;"><span style="color:#9ca3af;">Sábado - Domingo</span><span style="color:#F5A623;font-weight:600;">Cerrado</span></div>
            </div>
          </div>

          <!-- Mapa -->
          <div>
            <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:#F0F0F0;letter-spacing:0.04em;margin-bottom:16px;">Cómo Llegar</h3>
            <div style="border-radius:2px;overflow:hidden;border:1px solid #333;">
              <iframe
                src="https://maps.google.com/maps?q=39.5850871,2.6481269&output=embed"
                width="100%"
                height="300"
                style="border:0;display:block;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Ubicación de Electromecánica Eprom en Google Maps"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  @media (max-width: 767px) {
    .contact-grid {
      grid-template-columns: 1fr !important;
    }
    .form-row {
      grid-template-columns: 1fr !important;
    }
  }
</style>
