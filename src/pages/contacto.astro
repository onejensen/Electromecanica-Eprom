---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto - Pide Tu Cita" description="Contacta con Electromecánica Eprom en Palma de Mallorca. Pide tu cita por teléfono, WhatsApp o formulario. C/ Joan Fuster i Ortells, 24.">
  <!-- Header -->
  <section class="bg-primary-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Contacto</h1>
      <p class="text-neutral-200 text-lg max-w-2xl">¿Necesitas una revisión o reparación? Contacta con nosotros y te atenderemos lo antes posible.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Formulario -->
        <div>
          <h2 class="text-2xl font-bold text-primary-dark mb-6">Solicita tu cita</h2>
          <form action="https://formspree.io/f/PLACEHOLDER" method="POST" class="space-y-5">
            <div>
              <label for="nombre" class="block text-sm font-medium text-neutral-700 mb-1">Nombre completo *</label>
              <input type="text" id="nombre" name="nombre" required class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors" placeholder="Tu nombre">
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="telefono" class="block text-sm font-medium text-neutral-700 mb-1">Teléfono *</label>
                <input type="tel" id="telefono" name="telefono" required class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors" placeholder="600 000 000">
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">Email</label>
                <input type="email" id="email" name="email" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors" placeholder="tu@email.com">
              </div>
            </div>
            <div>
              <label for="vehiculo" class="block text-sm font-medium text-neutral-700 mb-1">Vehículo (marca, modelo, año)</label>
              <input type="text" id="vehiculo" name="vehiculo" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors" placeholder="Ej: Seat León 2019">
            </div>
            <div>
              <label for="servicio" class="block text-sm font-medium text-neutral-700 mb-1">Servicio requerido</label>
              <select id="servicio" name="servicio" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors bg-white">
                <option value="">Selecciona un servicio</option>
                <option value="diagnostico">Diagnóstico electrónico</option>
                <option value="electricidad">Electricidad del automóvil</option>
                <option value="mantenimiento">Mantenimiento preventivo</option>
                <option value="motor">Reparación de motor</option>
                <option value="aire">Aire acondicionado</option>
                <option value="frenos">Sistema de frenado</option>
                <option value="pre-itv">Pre-ITV</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div>
              <label for="mensaje" class="block text-sm font-medium text-neutral-700 mb-1">Describe tu problema o consulta</label>
              <textarea id="mensaje" name="mensaje" rows="4" class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors resize-y" placeholder="Cuéntanos qué le pasa a tu vehículo..."></textarea>
            </div>
            <button type="submit" class="w-full bg-accent hover:bg-accent-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors text-lg">
              Enviar Solicitud de Cita
            </button>
            <p class="text-xs text-neutral-400 text-center">Te contactaremos en menos de 24 horas para confirmar tu cita.</p>
          </form>
        </div>

        <!-- Info de contacto -->
        <div class="space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-primary-dark mb-6">Información de contacto</h2>
            <div class="space-y-4">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-neutral-800">Dirección</h3>
                  <p class="text-neutral-600">C/ Joan Fuster i Ortells, 24<br>07010 Palma, Mallorca</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-neutral-800">Teléfono</h3>
                  <a href="tel:+34971906236" class="text-primary hover:text-accent transition-colors font-medium">971 906 236</a>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-neutral-800">Email</h3>
                  <a href="mailto:electromecanicaeprom@gmail.com" class="text-primary hover:text-accent transition-colors font-medium">electromecanicaeprom@gmail.com</a>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-neutral-800">WhatsApp</h3>
                  <a href="https://wa.me/34971906236" target="_blank" rel="noopener noreferrer" class="text-green-600 hover:text-green-700 transition-colors font-medium">Enviar mensaje por WhatsApp</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Horario -->
          <div class="bg-neutral-50 rounded-xl p-6">
            <h3 class="font-bold text-primary-dark mb-4">Horario de atención</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-neutral-600">Lunes - Viernes</span><span class="font-medium">08:30 - 13:30 / 15:00 - 19:00</span></div>
              <div class="flex justify-between"><span class="text-neutral-600">Sábado</span><span class="text-accent font-medium">Cerrado</span></div>
              <div class="flex justify-between"><span class="text-neutral-600">Domingo</span><span class="text-accent font-medium">Cerrado</span></div>
            </div>
          </div>

          <!-- Mapa -->
          <div>
            <h3 class="font-bold text-primary-dark mb-4">Cómo llegar</h3>
            <div class="rounded-xl overflow-hidden shadow-sm">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3073.5!2d2.6253!3d39.5833!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sJoan+Fuster+i+Ortells+24+Palma!5e0!3m2!1ses!2ses!4v1"
                width="100%"
                height="300"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Ubicación de Electromecánica Eprom en Google Maps"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
