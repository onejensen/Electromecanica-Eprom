---

<Layout title="Servicios de Electromecánica" description="Servicios de electromecánica en Palma de Mallorca: diagnóstico electrónico, electricidad del automóvil, mantenimiento preventivo, reparación de motores y más.">
  <!-- Header -->
  <section class="bg-primary-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Nuestros Servicios</h1>
      <p class="text-neutral-200 text-lg max-w-2xl">Ofrecemos soluciones completas de electromecánica para todo tipo de vehículos. Calidad, profesionalidad y confianza.</p>
    </div>
  </section>

  <!-- Lista de servicios -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
      {servicios.map((s, i) => (
        <div class:list={['flex flex-col md:flex-row gap-8 items-start rounded-xl overflow-hidden', i % 2 === 0 ? 'bg-neutral-50' : 'bg-white']}>
          <img src={s.imagen} alt={s.titulo} style="width:100%;max-width:320px;height:220px;object-fit:cover;border-radius:8px 0 0 8px;flex-shrink:0;" />
          <div class="flex-1 p-8">
            <div class="flex items-center gap-4 mb-3">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icono}/>
                </svg>
              </div>
              <h2 class="text-2xl font-bold text-primary-dark">{s.titulo}</h2>
            </div>
            <p class="text-neutral-600 mb-4 leading-relaxed">{s.descripcion}</p>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {s.detalles.map(d => (
                <li class="flex items-center gap-2 text-sm text-neutral-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {d}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">¿Necesitas alguno de estos servicios?</h2>
      <p class="text-neutral-200 text-lg mb-8">Contacta con nosotros y te daremos presupuesto sin compromiso.</p>
      <a href="/contacto/" class="inline-flex items-center justify-center bg-accent hover:bg-accent-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors">
        Solicitar Presupuesto
      </a>
    </div>
  </section>
</Layout>
