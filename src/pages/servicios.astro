---
import Layout from '../layouts/Layout.astro';

const servicios = [
  {
    titulo: 'Diagnóstico Electrónico',
    imagen: 'https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?w=800&auto=format&fit=crop',
    descripcion: 'Utilizamos equipos de diagnóstico de última generación para leer y analizar los códigos de error de tu vehículo. Nuestro sistema permite identificar con precisión el origen de cualquier avería electrónica, ahorrando tiempo y costes innecesarios.',
    detalles: ['Lectura y borrado de códigos de avería (OBD-II)', 'Diagnóstico multimarca', 'Análisis de sensores y actuadores', 'Reprogramación de centralitas', 'Comprobación de sistemas electrónicos'],
    icono: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z',
  },
  {
    titulo: 'Electricidad del Automóvil',
    imagen: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&auto=format&fit=crop',
    descripcion: 'Somos especialistas en todos los sistemas eléctricos del vehículo. Desde la reparación del alternador hasta la instalación de accesorios eléctricos, nuestro equipo resuelve cualquier problema eléctrico.',
    detalles: ['Reparación de alternador y motor de arranque', 'Sistemas de iluminación y señalización', 'Instalación de accesorios eléctricos', 'Reparación de cableado', 'Sistemas de carga de batería', 'Cuadro de instrumentos'],
    icono: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    titulo: 'Mantenimiento Preventivo',
    imagen: 'https://images.unsplash.com/photo-1611161512722-ee6b8d748c9e?w=800&auto=format&fit=crop',
    descripcion: 'El mantenimiento regular es clave para evitar averías costosas y alargar la vida útil de tu vehículo. Realizamos revisiones completas siguiendo las recomendaciones del fabricante.',
    detalles: ['Cambio de aceite y filtros', 'Revisión de frenos', 'Control de niveles', 'Revisión de suspensión y dirección', 'Cambio de correa de distribución', 'Pre-ITV'],
    icono: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    titulo: 'Reparación de Motores',
    imagen: 'https://images.unsplash.com/photo-1580273916550-e323be2ae537?w=800&auto=format&fit=crop',
    descripcion: 'Nuestro equipo de mecánicos cualificados realiza reparaciones completas en motores gasolina y diésel. Desde pequeñas reparaciones hasta reconstrucciones completas.',
    detalles: ['Distribución y calado de motor', 'Junta de culata', 'Turbocompresor', 'Sistema de inyección', 'Embrague y caja de cambios', 'Sistema de refrigeración'],
    icono: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  },
  {
    titulo: 'Aire Acondicionado',
    imagen: 'https://images.unsplash.com/photo-1619642751034-765dfdf7c58e?w=800&auto=format&fit=crop',
    descripcion: 'Servicio completo de climatización del vehículo. Recarga de gas, detección de fugas y reparación de componentes del sistema de aire acondicionado.',
    detalles: ['Recarga de gas refrigerante', 'Detección y reparación de fugas', 'Sustitución de compresor', 'Limpieza del circuito', 'Cambio de filtro de habitáculo'],
    icono: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  },
  {
    titulo: 'Sistemas de Frenado',
    imagen: 'https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?w=800&auto=format&fit=crop',
    descripcion: 'La seguridad es lo primero. Revisamos y reparamos todo el sistema de frenado: pastillas, discos, líquido de frenos, ABS y sistemas de asistencia a la frenada.',
    detalles: ['Cambio de pastillas y discos', 'Purgado del sistema de frenos', 'Reparación de ABS', 'Freno de mano', 'Latiguillos y manguitos', 'Bombines y cilindros'],
    icono: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z',
  },
];
---

<Layout title="Servicios de Electromecánica" description="Servicios de electromecánica en Palma de Mallorca: diagnóstico electrónico, electricidad del automóvil, mantenimiento preventivo, reparación de motores y más.">
  <!-- Header -->
  <section style="background:#1A1A1A;padding:80px 0 48px;position:relative;border-bottom:3px solid #F5A623;">
    <div style="max-width:1280px;margin:0 auto;padding:0 24px;">
      <div style="display:inline-block;background:#F5A623;color:#111111;font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;padding:6px 16px;margin-bottom:16px;">Servicios</div>
      <h1 style="font-family:'Bebas Neue',sans-serif;font-size:clamp(2.5rem,5vw,5rem);color:#F0F0F0;line-height:1.0;letter-spacing:0.04em;">Nuestros Servicios</h1>
      <div style="width:80px;height:3px;background:#F5A623;margin-top:16px;"></div>
      <p style="color:#9ca3af;margin-top:16px;max-width:600px;font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;letter-spacing:0.02em;">Ofrecemos soluciones completas de electromecánica para todo tipo de vehículos. Calidad, profesionalidad y confianza.</p>
    </div>
  </section>

  <!-- Lista de servicios -->
  <section style="padding:64px 0;background:#1A1A1A;">
    <div style="max-width:1280px;margin:0 auto;padding:0 24px;display:flex;flex-direction:column;gap:24px;">
      {servicios.map((s, i) => (
        <div class="service-detail-card" style={`display:flex;flex-direction:${i % 2 === 0 ? 'row' : 'row-reverse'};gap:0;background:#242424;border-top:3px solid #F5A623;border-left:1px solid #333;border-right:1px solid #333;border-bottom:1px solid #333;border-radius:2px;overflow:hidden;animation:fadeInUp 0.6s ease-out ${(i*0.1)+0.2}s both;`}>
          <img src={s.imagen} alt={s.titulo} style="width:360px;min-height:280px;object-fit:cover;flex-shrink:0;" class="service-detail-img" />
          <div style="flex:1;padding:36px 32px;">
            <div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;">
              <div style="width:48px;height:48px;background:#F5A623;border-radius:2px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:24px;width:24px;color:#111111;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icono}/>
                </svg>
              </div>
              <h2 style="font-family:'Bebas Neue',sans-serif;font-size:2rem;color:#F0F0F0;letter-spacing:0.04em;line-height:1;">{s.titulo}</h2>
            </div>
            <p style="color:#b0b8c1;font-size:1rem;line-height:1.7;font-family:'Barlow Condensed',sans-serif;margin-bottom:20px;">{s.descripcion}</p>
            <ul style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:8px;">
              {s.detalles.map(d => (
                <li style="display:flex;align-items:center;gap:8px;font-size:0.9rem;color:#9ca3af;font-family:'Barlow Condensed',sans-serif;">
                  <svg xmlns="http://www.w3.org/2000/svg" style="height:16px;width:16px;color:#F5A623;flex-shrink:0;" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {d}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:96px 0;background:#242424;border-top:3px solid #F5A623;">
    <div style="max-width:768px;margin:0 auto;padding:0 24px;text-align:center;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:clamp(2.5rem,5vw,5rem);color:#F0F0F0;margin-bottom:8px;letter-spacing:0.04em;">¿Necesitas alguno de estos servicios?</h2>
      <div style="width:80px;height:3px;background:#F5A623;margin:0 auto 24px;"></div>
      <p style="color:#b0b8c1;font-size:1.1rem;margin-bottom:40px;font-family:'Barlow Condensed',sans-serif;letter-spacing:0.02em;">Contacta con nosotros y te daremos presupuesto sin compromiso.</p>
      <a href={`${import.meta.env.BASE_URL}contacto/`} style="padding:16px 48px;background:#F5A623;color:#111111;font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;font-weight:700;text-decoration:none;border-radius:2px;text-transform:uppercase;letter-spacing:0.1em;transition:background 0.15s,transform 0.15s;display:inline-block;" onmouseover="this.style.background='#c97d10';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#F5A623';this.style.transform='translateY(0)'">
        Solicitar Presupuesto
      </a>
    </div>
  </section>
</Layout>

<style>
  @media (max-width: 767px) {
    .service-detail-card {
      flex-direction: column !important;
    }
    .service-detail-img {
      width: 100% !important;
      height: 200px !important;
    }
  }
</style>
