---
import Layout from '../layouts/Layout.astro';

const servicios = [
  {
    titulo: 'Diagnóstico Electrónico',
    descripcion: 'Lectura y borrado de códigos de error con equipos de última generación. Identificamos el problema con precisión.',
    icono: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z',
  },
  {
    titulo: 'Electricidad del Automóvil',
    descripcion: 'Reparación de sistemas eléctricos: alternador, motor de arranque, iluminación, cableado y más.',
    icono: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    titulo: 'Mantenimiento Preventivo',
    descripcion: 'Revisiones periódicas para mantener tu vehículo en óptimas condiciones y evitar averías costosas.',
    icono: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    titulo: 'Reparación de Motores',
    descripcion: 'Diagnóstico y reparación completa de motores gasolina y diésel con garantía de calidad.',
    icono: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  },
];
---

<Layout title="Taller Electromecánica en Palma de Mallorca" description="Electromecánica Eprom - Taller de electromecánica en Palma de Mallorca. Diagnóstico electrónico, electricidad del automóvil, mantenimiento preventivo y reparación de motores.">
  <!-- Hero -->
  <section class="relative bg-primary-dark text-white overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1619642751034-765dfdf7c58e?w=1600&q=80"
      alt="Taller electromecánica"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/95 via-primary-dark/80 to-primary/70"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Tu taller de <span class="text-accent-light">electromecánica</span> de confianza en Palma
        </h1>
        <p class="text-lg md:text-xl text-neutral-200 mb-8 leading-relaxed">
          Especialistas en diagnóstico electrónico, electricidad del automóvil y mantenimiento preventivo. Más de 20 años cuidando de tu vehículo en Mallorca.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contacto/" class="inline-flex items-center justify-center bg-accent hover:bg-accent-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors text-lg">
            Pedir Cita
          </a>
          <a href="tel:+34971906236" class="inline-flex items-center justify-center border-2 border-white hover:bg-white hover:text-primary-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors text-lg">
            Llamar Ahora
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios destacados -->
  <section class="py-20 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-4">Nuestros Servicios</h2>
        <p class="text-neutral-500 text-lg max-w-2xl mx-auto">Soluciones completas de electromecánica para tu vehículo con la última tecnología</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {servicios.map(s => (
          <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow border border-neutral-100">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icono}/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-primary-dark mb-2">{s.titulo}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">{s.descripcion}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/servicios/" class="inline-flex items-center text-primary font-semibold hover:text-accent transition-colors">
          Ver todos los servicios
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Por qué elegirnos -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-4">¿Por Qué Elegirnos?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-primary-dark mb-2">Rapidez</h3>
          <p class="text-neutral-500">Diagnósticos rápidos y reparaciones eficientes para que recuperes tu vehículo cuanto antes.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-primary-dark mb-2">Confianza</h3>
          <p class="text-neutral-500">Presupuestos sin compromiso y total transparencia en cada reparación que realizamos.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-primary-dark mb-2">Tecnología</h3>
          <p class="text-neutral-500">Equipos de diagnóstico de última generación para identificar y solucionar cualquier avería.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">¿Necesitas una revisión?</h2>
      <p class="text-neutral-200 text-lg mb-8">Pide tu cita ahora y te atenderemos lo antes posible. Presupuesto sin compromiso.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contacto/" class="inline-flex items-center justify-center bg-accent hover:bg-accent-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors">
          Solicitar Cita
        </a>
        <a href="https://wa.me/34971906236" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-green-500 hover:bg-green-600 text-white font-semibold px-8 py-3 rounded-lg transition-colors">
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>
