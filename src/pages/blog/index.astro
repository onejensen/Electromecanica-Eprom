---
import Layout from '../../layouts/Layout.astro';

const articulos = [
  {
    slug: 'cuando-cambiar-bujias',
    titulo: '¿Cuándo cambiar las bujías de tu coche?',
    resumen: 'Descubre las señales que indican que es hora de cambiar las bujías y por qué es importante para el rendimiento de tu motor.',
    fecha: '15 de marzo de 2026',
  },
  {
    slug: 'sintomas-alternador-averiado',
    titulo: 'Síntomas de un alternador averiado',
    resumen: 'Aprende a identificar los síntomas más comunes de un alternador en mal estado antes de que te deje tirado.',
    fecha: '10 de marzo de 2026',
  },
  {
    slug: 'que-es-diagnosis-electronica',
    titulo: '¿Qué es la diagnosis electrónica del automóvil?',
    resumen: 'Te explicamos en qué consiste la diagnosis electrónica, cómo funciona y por qué es fundamental para el mantenimiento moderno.',
    fecha: '5 de marzo de 2026',
  },
  {
    slug: 'cuando-pasar-itv',
    titulo: '¿Cuándo hay que pasar la ITV? Guía completa',
    resumen: 'Todo lo que necesitas saber sobre los plazos de la ITV, qué se revisa y cómo preparar tu vehículo.',
    fecha: '28 de febrero de 2026',
  },
  {
    slug: 'mantenimiento-preventivo-basico',
    titulo: 'Mantenimiento preventivo básico: guía para conductores',
    resumen: 'Las revisiones básicas que puedes hacer para alargar la vida de tu vehículo y evitar averías costosas.',
    fecha: '20 de febrero de 2026',
  },
];
---

<Layout title="Blog - Consejos de Electromecánica" description="Blog de Electromecánica Eprom. Consejos sobre mantenimiento del automóvil, diagnóstico electrónico, ITV y más. Taller en Palma de Mallorca.">
  <!-- Header -->
  <section style="background:#1A1A1A;padding:80px 0 48px;position:relative;border-bottom:3px solid #F5A623;">
    <div style="max-width:1280px;margin:0 auto;padding:0 24px;">
      <div style="display:inline-block;background:#F5A623;color:#111111;font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;padding:6px 16px;margin-bottom:16px;">Blog</div>
      <h1 style="font-family:'Bebas Neue',sans-serif;font-size:clamp(2.5rem,5vw,5rem);color:#F0F0F0;line-height:1.0;letter-spacing:0.04em;">Consejos y Guías</h1>
      <div style="width:80px;height:3px;background:#F5A623;margin-top:16px;"></div>
      <p style="color:#9ca3af;margin-top:16px;max-width:600px;font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;letter-spacing:0.02em;">Consejos y guías sobre mantenimiento, averías y todo lo que necesitas saber sobre tu vehículo.</p>
    </div>
  </section>

  <!-- Articles -->
  <section style="padding:64px 0;background:#1A1A1A;">
    <div style="max-width:900px;margin:0 auto;padding:0 24px;display:flex;flex-direction:column;gap:16px;">
      {articulos.map((a, i) => (
        <article style={`background:#242424;border-top:3px solid #F5A623;border-left:1px solid #333;border-right:1px solid #333;border-bottom:1px solid #333;border-radius:2px;padding:28px 32px;transition:transform 0.2s,box-shadow 0.2s;animation:fadeInUp 0.6s ease-out ${(i*0.1)+0.1}s both;`} class="service-card-3d">
          <a href={`${import.meta.env.BASE_URL}blog/${a.slug}/`} style="text-decoration:none;display:block;">
            <time style="font-size:0.8rem;color:#666;font-family:'Barlow Condensed',sans-serif;text-transform:uppercase;letter-spacing:0.08em;">{a.fecha}</time>
            <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.8rem;color:#F0F0F0;letter-spacing:0.04em;margin:8px 0 12px;line-height:1.1;">{a.titulo}</h2>
            <p style="color:#9ca3af;font-family:'Barlow Condensed',sans-serif;font-size:1rem;line-height:1.6;">{a.resumen}</p>
            <span style="display:inline-flex;align-items:center;gap:6px;margin-top:16px;color:#F5A623;font-family:'Barlow Condensed',sans-serif;font-size:0.9rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;">
              Leer más
              <svg xmlns="http://www.w3.org/2000/svg" style="height:16px;width:16px;" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </span>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
