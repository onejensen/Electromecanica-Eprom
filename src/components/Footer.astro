      </div>

      <!-- Hours -->
      <div>
        <h4 class="text-white font-semibold mb-4">Horario</h4>
        <ul class="space-y-1 text-sm">
          <li class="flex justify-between"><span>Lunes - Jueves</span><span>08:00 - 17:00</span></li>
          <li class="flex justify-between"><span>Viernes</span><span>08:00 - 14:00</span></li>
          <li class="flex justify-between mt-2"><span>Sábado - Domingo</span><span class="text-accent-light">Cerrado</span></li>
        </ul>
      </div>
    </div>

    <!-- Google Maps embed -->
    <div style="margin-top:40px;border-radius:4px;overflow:hidden;border:1px solid #333;">
      <iframe
        src="https://maps.google.com/maps?q=39.5850871,2.6481269&output=embed"
        width="100%"
        height="300"
        style="border:0;display:block;"
        allowfullscreen=""
        loading="lazy"
        title="Localización Palma de Mallorca"
      ></iframe>
    </div>

    <div class="border-t border-neutral-700 mt-8 pt-6 text-center text-xs text-neutral-400">
      &copy; {year} Electromecánica Eprom. Todos los derechos reservados.
