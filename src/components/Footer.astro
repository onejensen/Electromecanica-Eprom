---
const year = new Date().getFullYear();
---

<footer class="bg-primary-dark text-neutral-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Info -->
      <div>
        <div class="mb-4">
          <img src="/logo.png" alt="Electromecánica Eprom" class="h-12 w-auto" />
        </div>
        <p class="text-sm leading-relaxed">
          Taller de electromecánica en Palma de Mallorca. Especialistas en diagnóstico electrónico, electricidad del automóvil y mantenimiento preventivo.
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-semibold mb-4">Contacto</h4>
        <ul class="space-y-2 text-sm">
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Joan Fuster i Ortells, 24, Palma 07010
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href="tel:+34971906236" class="hover:text-white transition-colors">971 906 236</a>
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href="mailto:electromecanicaeprom@gmail.com" class="hover:text-white transition-colors">electromecanicaeprom@gmail.com</a>
          </li>
        </ul>
      </div>

      <!-- Hours -->
      <div>
        <h4 class="text-white font-semibold mb-4">Horario</h4>
        <ul class="space-y-1 text-sm">
          <li class="flex justify-between"><span>Lunes - Viernes</span><span>08:30 - 13:30</span></li>
          <li class="flex justify-between"><span></span><span>15:00 - 19:00</span></li>
          <li class="flex justify-between mt-2"><span>Sábado - Domingo</span><span class="text-accent-light">Cerrado</span></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-neutral-700 mt-8 pt-6 text-center text-xs text-neutral-400">
      &copy; {year} Electromecánica Eprom. Todos los derechos reservados.
    </div>
  </div>
</footer>
