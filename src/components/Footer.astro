---
const year = new Date().getFullYear();
---

<footer class="bg-primary-dark text-neutral-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Info -->
      <div>
        <div class="mb-4">
          <img src="/logo.png" alt="Electromecánica Eprom" class="h-12 w-auto" />
        </div>
        <p class="text-sm leading-relaxed">
          Taller de electromecánica en Palma de Mallorca. Especialistas en diagnóstico electrónico, electricidad del automóvil y mantenimiento preventivo.
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-semibold mb-4">Contacto</h4>
        <ul class="space-y-2 text-sm">
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
