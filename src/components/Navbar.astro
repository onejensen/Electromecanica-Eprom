---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/', label: 'Inicio' },
  { href: '/servicios/', label: 'Servicios' },
  { href: '/galeria/', label: 'Galería' },
  { href: '/blog/', label: 'Blog' },
  { href: '/contacto/', label: 'Contacto' },
];
---

<nav style="background:#111111;border-bottom:3px solid #F5A623;position:sticky;top:0;z-index:50;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div style="display:flex;align-items:center;justify-content:space-between;height:72px;">
      <a href="/" style="display:flex;align-items:center;gap:12px;text-decoration:none;">
        <img src="/logo.png" alt="Electromecánica Eprom" style="max-height:48px;width:auto;object-fit:contain;" />
      </a>

      <!-- Desktop menu -->
      <div class="hidden md:flex" style="gap:4px;align-items:center;">
        {links.map(link => (
          <a
            href={link.href}
            style={`padding:8px 16px;font-family:'Archivo Black',sans-serif;font-size:0.8rem;text-decoration:none;text-transform:uppercase;letter-spacing:0.08em;transition:color 0.15s;color:${currentPath === link.href ? '#F5A623' : '#d1d5db'};border-bottom:${currentPath === link.href ? '2px solid #F5A623' : '2px solid transparent'};`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <a href="tel:+34971906236" class="hidden md:inline-flex" style="align-items:center;gap:8px;background:#F5A623;color:#111111;padding:12px 24px;border-radius:4px;font-family:'Archivo Black',sans-serif;font-size:0.8rem;text-decoration:none;text-transform:uppercase;letter-spacing:0.08em;font-weight:900;transition:background 0.15s;box-shadow:3px 3px 0 #c97d10;" onmouseover="this.style.background='#c97d10'" onmouseout="this.style.background='#F5A623'">
        <svg xmlns="http://www.w3.org/2000/svg" style="height:16px;width:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        971 906 236
      </a>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden" style="background:none;border:2px solid #F5A623;padding:6px 10px;cursor:pointer;border-radius:4px;color:#fff;" aria-label="Abrir menú">
        <svg xmlns="http://www.w3.org/2000/svg" style="height:24px;width:24px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden" style="padding-bottom:16px;border-top:1px solid #1f2937;">
      {links.map(link => (
        <a
          href={link.href}
          style={`display:block;padding:12px 8px;font-family:'Archivo Black',sans-serif;font-size:0.85rem;text-decoration:none;text-transform:uppercase;letter-spacing:0.08em;color:${currentPath === link.href ? '#F5A623' : '#d1d5db'};border-left:${currentPath === link.href ? '3px solid #F5A623' : '3px solid transparent'};padding-left:${currentPath === link.href ? '12px' : '8px'};`}
        >
          {link.label}
        </a>
      ))}
      <a href="tel:+34971906236" style="display:block;margin-top:12px;text-align:center;background:#F5A623;color:#111111;padding:12px 24px;border-radius:4px;font-family:'Archivo Black',sans-serif;font-size:0.85rem;text-decoration:none;text-transform:uppercase;letter-spacing:0.08em;font-weight:900;">
        971 906 236
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
